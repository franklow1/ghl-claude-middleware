# ============================================
# CONFIGURACIÓN DEL MIDDLEWARE
# Copia este archivo como .env y llena los valores
# ============================================

# Tu API key de Anthropic (Claude)
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Tu API key de GoHighLevel
# En GHL: Settings → Business Profile → API Key
# O usa OAuth: Settings → Integrations → API Keys
GHL_API_KEY=tu-ghl-api-key

# Link de pago de tu comunidad en Skool
SKOOL_PAYMENT_LINK=https://www.skool.com/tu-comunidad

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000
